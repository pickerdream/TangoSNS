apiVersion: v1
kind: Secret
metadata:
  name: tangosns-secret
  namespace: tangosns
type: Opaque
data:
  # 以下はプレースホルダーです。デプロイ前に実際の値を base64 エンコードして置き換えてください。
  # echo -n "your_value" | base64
  PGPASSWORD: Y2hhbmdlLW1l        # change-me
  JWT_SECRET: Y2hhbmdlLW1l        # change-me
  # GOOGLE_CLIENT_ID: (必要な場合のみ設定)
