services:
  db:
    image: postgres:15-alpine
    restart: unless-stopped
    environment:
      POSTGRES_USER: tangosns_user
      POSTGRES_PASSWORD: tangosns_pass
      POSTGRES_DB: tangosns
    volumes:
      - pgdata:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U tangosns_user -d tangosns"]
      interval: 5s
      timeout: 3s
      retries: 5

  app:
    build: .
    restart: unless-stopped
    depends_on:
      db:
        condition: service_healthy
    environment:
      PGHOST: db
      PGUSER: tangosns_user
      PGPASSWORD: tangosns_pass
      PGDATABASE: tangosns
      PGPORT: 5432
      JWT_SECRET: change-me-to-a-secure-random-string
      PORT: 3000
      # GOOGLE_CLIENT_ID: your_google_client_id_here
    ports:
      - "3000:3000"

volumes:
  pgdata:
